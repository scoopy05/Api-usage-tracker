{
    "extends": "@ljharb/tsconfig",   // points to node_modules/@ljharb/tsconfig
    "compilerOptions": {
      "target": "es5",
      "rootDir": "./src",
      "baseUrl": "./src",
      "jsx": "react-jsx",
      "allowJs": true,
      "esModuleInterop": true,
      "moduleResolution": "node"
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
  }